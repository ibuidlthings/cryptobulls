# Solana RPC. Helius URL recommended (free tier OK at launch).
RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
WS_URL=wss://mainnet.helius-rpc.com/?api-key=YOUR_KEY

# Bullpeg program ID (matches declare_id! in lib.rs).
PROGRAM_ID=BLpgSo1aBu11pegSo1aBu11pegSo1aBu11pegSo1aBu11

# $UPEG mint address from pump.fun launch. Empty until launch.
TOKEN_MINT=

# Cranker keypair (pays tx fees + BullAsset rent). Generate with:
#   solana-keygen new -o cranker-keypair.json
# Fund with ~15 SOL (covers worst-case 1000 mints + tx fees).
KEYPAIR_PATH=./cranker-keypair.json

# Webhook port (Helius will POST here on token transfers).
PORT=7777
